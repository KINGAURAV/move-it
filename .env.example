# Copy this file to `.env` at the move-it repo root and fill in real values.
# cp .env.example .env
# Never commit `.env` — it is listed in `.gitignore`.

# --- Vayu Object Storage (S3) — Step 1 ---
# Credentials provided in the Access Guide
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
S3_ENDPOINT=<your-s3-endpoint>
S3_BUCKET_NAME=<your-bucket-name>
S3_DATASET_KEY=cropdata.csv
S3_MODEL_KEY=move-it/model.joblib

# --- Vayu MLflow — Step 2 ---
# Connect page: Public Endpoint + credentials set at create time
MLFLOW_TRACKING_URL=https://<your-mlflow-host>
MLFLOW_TRACKING_USERNAME=<your-username>
MLFLOW_TRACKING_PASSWORD=<your-password>

# --- Vayu Kafka — Step 3 ---
# Credentials provided in the Access Guide
# Form KAFKA_BROKER from the Access Guide as <IP>:<PORT>
KAFKA_BROKER=<your-kafka-broker-url>
KAFKA_USERNAME=<your-kafka-username>
KAFKA_PASSWORD=<your-kafka-password>
# Topic name — 03_vayu_kafka/create_topic.py creates a topic with this name
KAFKA_TOPIC=greenhouse_telemetry

# --- Vayu Container Registry — Step 8 ---
# Credentials provided in the Access Guide
# Host only — do not include https://, http://, or a trailing /
IMAGE_REGISTRY=<your-image-registry>
REGISTRY_PROJECT=<your-registry-project>
REGISTRY_USERNAME=<container-registry-username>
REGISTRY_PASSWORD=<container-registry-password>
VAYU_USERNAME=<your-vayu-username>
